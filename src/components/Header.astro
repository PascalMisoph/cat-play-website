---
export type Props = {
  currentPath?: string;
};

const { currentPath = "/" } = Astro.props;

const isActive = (path: string) =>
  path === "/" ? currentPath === "/" : currentPath.startsWith(path);

const aboutHref = currentPath === "/" ? "#top" : "/#top";
const waitlistHref =
  currentPath === "/" ||
  currentPath.startsWith("/how-it-works") ||
  currentPath.startsWith("/benefits")
    ? "#waitlist"
    : "/#waitlist";
---

<nav id="top" class="site-nav" aria-label="Primary">
  <div class="nav-shell">
    <div class="nav-inner">
      <a href="/" class="nav-logo">cat<span class="play">play</span></a>

      <ul class="nav-links">
        <li>
          <a href={aboutHref}>About</a>
        </li>
        <li>
          <a href="/how-it-works" aria-current={isActive("/how-it-works") ? "page" : undefined}>
            How it works
          </a>
        </li>
        <li>
          <a href="/benefits" aria-current={isActive("/benefits") ? "page" : undefined}>
            Benefits
          </a>
        </li>
        <li>
          <a href={waitlistHref} class="nav-cta">Join waitlist</a>
        </li>
      </ul>

      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu">
        <span class="nav-toggle-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="sr-only">Menu</span>
      </button>
    </div>

    <div class="nav-mobile-menu" id="mobile-menu" hidden>
      <a href={aboutHref}>About</a>
      <a href="/how-it-works" aria-current={isActive("/how-it-works") ? "page" : undefined}>
        How it works
      </a>
      <a href="/benefits" aria-current={isActive("/benefits") ? "page" : undefined}>Benefits</a>
      <a href={waitlistHref} class="nav-mobile-cta">Join waitlist</a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(251, 247, 241, 0.88);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(123, 97, 72, 0.08);
  }

  .nav-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .nav-inner {
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-logo {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.05em;
    color: #34271f;
    text-decoration: none;
  }

  .play {
    color: #c39a7b;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
  }

  .nav-links a {
    font-size: 13.5px;
    color: rgba(76, 60, 47, 0.74);
    text-decoration: none;
    font-weight: 500;
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .nav-links a[aria-current="page"] {
    color: #5c483a;
  }

  .nav-links a:hover {
    color: #5c483a;
  }

  .nav-cta {
    background: var(--apricot-500);
    color: var(--apricot-ink) !important;
    padding: 10px 18px;
    border-radius: 0;
    font-size: 13px;
    font-weight: 500;
  }

  .nav-cta:hover {
    background: var(--apricot-600);
    color: var(--apricot-ink) !important;
  }

  .nav-mobile-links {
    display: none;
  }

  .nav-toggle {
    display: none;
    border: 1px solid rgba(123, 97, 72, 0.14);
    background: rgba(255, 251, 245, 0.72);
    color: #5c483a;
    padding: 12px 13px;
    cursor: pointer;
  }

  .nav-toggle-icon {
    display: grid;
    gap: 4px;
    width: 18px;
  }

  .nav-toggle-icon span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: currentColor;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 960px) {
    .nav-links {
      display: none;
    }

    .nav-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .nav-mobile-menu {
      display: grid;
      gap: 0;
      padding: 0 20px 16px;
    }

    .nav-mobile-menu[hidden] {
      display: none !important;
    }

    .nav-mobile-menu a {
      display: block;
      padding: 14px 0;
      border: 0;
      border-bottom: 1px solid rgba(123, 97, 72, 0.12);
      color: #5c483a;
      text-decoration: none;
      font-size: 14px;
      line-height: 1.2;
      background: transparent;
    }

    .nav-mobile-cta {
      margin-top: 12px;
      padding: 12px 14px !important;
      border-bottom: 0 !important;
      border-color: transparent !important;
      background: var(--apricot-500) !important;
      color: var(--apricot-ink) !important;
      font-weight: 500;
    }
  }

  @media (max-width: 540px) {
    .nav-inner {
      padding: 14px 20px;
    }
  }
</style>

<script is:inline>
  if (!window.__catplayHeaderMenuBound) {
    const closeMenus = () => {
      document.querySelectorAll(".nav-toggle").forEach((toggle) => {
        if (!(toggle instanceof HTMLButtonElement)) {
          return;
        }

        const nav = toggle.closest(".site-nav");
        const menu = nav?.querySelector("#mobile-menu");
        if (!(menu instanceof HTMLElement)) {
          return;
        }

        toggle.setAttribute("aria-expanded", "false");
        menu.hidden = true;
      });
    };

    const syncMenusOnLoad = () => {
      document.querySelectorAll(".site-nav").forEach((nav) => {
        const toggle = nav.querySelector(".nav-toggle");
        const menu = nav.querySelector("#mobile-menu");
        if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) {
          return;
        }

        toggle.setAttribute("aria-expanded", "false");
        menu.hidden = true;
      });
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      const toggle = target.closest(".nav-toggle");
      if (toggle instanceof HTMLButtonElement) {
        const nav = toggle.closest(".site-nav");
        const menu = nav?.querySelector("#mobile-menu");
        if (!(menu instanceof HTMLElement)) {
          return;
        }

        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        closeMenus();
        if (!isOpen) {
          toggle.setAttribute("aria-expanded", "true");
          menu.hidden = false;
        }
        return;
      }

      if (target.closest("#mobile-menu a")) {
        closeMenus();
        return;
      }

      if (!target.closest(".site-nav")) {
        closeMenus();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenus();
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 960) {
        closeMenus();
      }
    });

    document.addEventListener("astro:page-load", syncMenusOnLoad);
    syncMenusOnLoad();
    window.__catplayHeaderMenuBound = true;
  }
</script>
