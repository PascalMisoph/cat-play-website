---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import WaitlistForm from "../components/WaitlistForm.astro";

const steps = [
  {
    number: "01",
    kicker: "Set up your cat",
    title: "Create your cat's profile in minutes.",
    body:
      "Add the little things that make them who they are. Their age, personality, favorite toys, and more. So CatPlay can be personal from day one.",
    note: "Built for your cat. Not just any cat.",
    phoneAsset: "/how-it-works/phone-profile.png",
  },
  {
    number: "02",
    kicker: "Play together every day",
    title: "Get a gentle nudge. Start a play session.",
    body:
      "A daily reminder helps you pause and connect. Short, focused play sessions that fit your day and make a real difference.",
    note: "Small ritual. Big impact.",
    phoneAsset: "/how-it-works/phone-session.png",
  },
  {
    number: "03",
    kicker: "See what matters",
    title: "Understand, reflect, grow together.",
    body:
      "See your progress, learn your cat's patterns, and celebrate the little wins together.",
    note: "Insights that bring you closer.",
    phoneAsset: "/how-it-works/phone-report.png",
  },
];
---

<BaseLayout
  title="How CatPlay Works"
  description="CatPlay helps you build a quiet daily play ritual, track what matters, and understand your cat on a deeper level."
>
  <Header currentPath="/how-it-works" />

  <main class="how-shell">
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <span class="section-kicker">How it works</span>
          <h1>
            A small daily ritual
            <br />
            that <em>changes everything.</em>
          </h1>
          <p>
            CatPlay helps you build a quiet daily play ritual, track what matters, and understand
            your cat on a deeper level.
          </p>
        </div>

        <div class="hero-media-wrap">
          <div class="hero-media">
            <img
              src="/how-it-works/hero-cat-sunlight.jpg"
              alt="Cat resting in warm sunlight"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="steps-section">
      <div class="container">
        {
          steps.map((step) => (
            <article class="step-row">
              <div class="step-copy">
                <div class="section-number step-number">{step.number}</div>
                <span class="step-kicker">{step.kicker}</span>
                <h2>{step.title}</h2>
                <p>{step.body}</p>
                <div class="step-note">{step.note}</div>
              </div>

              <div class="phone-shell">
                <img
                  class="phone-image"
                  src={step.phoneAsset}
                  alt={`${step.title} screen in the CatPlay app`}
                  loading="lazy"
                />
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="waitlist" class="cta-section">
      <div class="container cta-grid">
        <div class="cta-image">
          <img
            src="/how-it-works/cta-play-cat.jpg"
            alt="Cat playing with a feather toy"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="cta-copy">
          <h2>Ready to build a better routine for you and your cat?</h2>
          <p>Join the waitlist and be the first to play.</p>
          <div class="cta-form">
            <WaitlistForm id="waitlist-how" variant="editorial" />
          </div>
          <div class="cta-note">No spam. Just good things for cat people.</div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .how-shell {
    background: #f8f1e7;
    color: #2b211a;
  }

  .hero-section {
    padding: 18px 0 36px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: 48px;
    align-items: start;
  }

  .hero-copy {
    padding-top: 76px;
    max-width: 560px;
  }

  .hero-copy h1 {
    font-size: clamp(54px, 7vw, 76px);
    line-height: 1.03;
    letter-spacing: -0.055em;
    font-weight: 400;
    color: #402f25;
    margin-bottom: 24px;
  }

  .hero-copy h1 em {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-weight: 400;
    color: var(--editorial-italic-accent);
  }

  .hero-copy p {
    max-width: 430px;
    color: rgba(63, 46, 36, 0.88);
    font-size: 17px;
    line-height: 1.7;
  }

  .hero-media-wrap {
    padding-top: 34px;
  }

  .hero-media {
    aspect-ratio: 0.94;
    width: 100%;
    border: 1px solid rgba(236, 170, 123, 0.08);
    overflow: hidden;
    background: #ead8c3;
  }

  .hero-media img,
  .cta-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .steps-section {
    padding-bottom: 24px;
  }

  .step-row {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(260px, 0.78fr);
    gap: 24px;
    align-items: center;
    padding: 28px 0 36px;
    border-top: 1px solid rgba(223, 206, 185, 0.9);
  }

  .step-row:first-child {
    border-top: 0;
  }

  .step-copy {
    max-width: 470px;
  }

  .step-number {
    margin-bottom: 28px;
  }

  .step-kicker {
    display: inline-block;
    margin-bottom: 12px;
    color: #ecaa7b;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 13px;
    font-weight: 500;
  }

  .step-copy h2 {
    font-size: clamp(44px, 5vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.05em;
    font-weight: 400;
    color: #402f25;
    max-width: 560px;
    margin-bottom: 20px;
  }

  .step-copy p {
    max-width: 430px;
    color: rgba(63, 46, 36, 0.84);
    font-size: 16px;
    line-height: 1.72;
  }

  .step-note {
    margin-top: 28px;
    color: #7f624c;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 17px;
  }

  .phone-shell {
    display: flex;
    justify-content: center;
  }

  .phone-image {
    width: min(100%, 270px);
    height: auto;
    display: block;
  }

  .cta-section {
    padding: 0 0 40px;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.92fr) minmax(0, 1fr);
    align-items: stretch;
    background: rgba(255, 249, 241, 0.44);
  }

  .cta-image {
    min-height: 250px;
    overflow: hidden;
  }

  .cta-copy {
    padding: 42px 44px;
    display: grid;
    align-content: center;
    gap: 12px;
  }

  .cta-copy h2 {
    max-width: 500px;
    font-size: clamp(34px, 4vw, 48px);
    line-height: 1.08;
    letter-spacing: -0.045em;
    font-weight: 400;
    color: #402f25;
  }

  .cta-copy p,
  .cta-note {
    color: rgba(63, 46, 36, 0.84);
    font-size: 15px;
    line-height: 1.6;
  }

  .cta-form {
    max-width: 520px;
    margin-top: 6px;
  }

  .cta-note {
    font-size: 13px;
  }

  @media (max-width: 1080px) {
    .hero-grid,
    .step-row,
    .cta-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      padding-top: 48px;
    }

    .hero-media-wrap {
      padding-top: 0;
      max-width: 520px;
      margin-left: auto;
    }

    .phone-shell {
      justify-content: flex-start;
      padding-top: 8px;
    }
  }

  @media (max-width: 720px) {
    .hero-section {
      padding-top: 8px;
    }

    .hero-copy h1 {
      font-size: 50px;
    }

    .hero-media-wrap {
      margin-left: 0;
    }

    .step-row {
      padding: 18px 0 28px;
    }

    .step-copy h2 {
      font-size: 42px;
    }

    .cta-copy {
      padding: 28px 24px 32px;
    }

    .cta-image {
      min-height: 210px;
    }
  }
</style>
