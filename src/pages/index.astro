---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import WaitlistForm from "../components/WaitlistForm.astro";

const trustPublications = ["Paw & Sage"];

const featureItems = [
  {
    number: "01",
    title: "Behavior insights",
    description: "See what is really going on beneath the surface.",
  },
  {
    number: "02",
    title: "Routine building",
    description: "Create daily rituals that bring stability and calm.",
  },
  {
    number: "03",
    title: "Personalized guidance",
    description: "Get gentle, science-based suggestions that fit your cat.",
  },
];

const faqItems = [
  {
    question: "When will CatPlay be available?",
    answer:
      "We are preparing early access now. Waitlist members will hear first when invites open.",
  },
  {
    question: "Is CatPlay only for one cat?",
    answer:
      "No. CatPlay is being built with multi-cat homes in mind, so the product can hold one rhythm or a whole household.",
  },
  {
    question: "Can CatPlay really help with behavior?",
    answer:
      "CatPlay is designed to improve consistency around play, routine, and observation. The goal is clearer reads, calmer days, and better support for the cat in your home.",
  },
];
---

<BaseLayout
  title="CatPlay | A small daily ritual with your cat"
  description="CatPlay is a calm, intelligent space to understand your cat, support their wellbeing, and build routines that truly help."
>
  <Header currentPath="/" />

  <main class="landing-shell">
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">Coming soon</span>
          <h1>
            Wellness
            <br />
            is a <em>daily ritual.</em>
          </h1>
          <p class="hero-body">
            CatPlay is a calm, intelligent space to understand your cat, support their wellbeing,
            and build routines that truly help.
          </p>
          <div class="hero-form hero-form-desktop">
            <WaitlistForm
              id="waitlist-hero"
              variant="editorial"
            />
          </div>
        </div>

        <div class="hero-media">
          <div class="media-frame hero-media-frame">
            <img
              src="/landing/hero-cat.jpg"
              alt="Cat resting calmly in a warm blanket"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>

        <div class="hero-form hero-form-mobile">
          <WaitlistForm
            id="waitlist-hero-mobile"
            variant="editorial"
          />
        </div>
      </div>
    </section>

    <section class="trust-bar">
      <div class="container trust-inner">
        <p class="trust-statement">
          Thoughtfully designed for cats and the people who love them.
        </p>
        <div class="trust-logos">
          {
            trustPublications.map((publication) => (
              <div class="trust-logo-item">
                <div class="trust-logo-name">{publication}</div>
                <div class="trust-logo-meta">FEATURED</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="about" class="story-section">
      <div class="container story-grid">
        <div class="story-media">
          <div class="media-frame story-media-frame">
            <img
              src="/landing/still-life.jpg"
              alt="Cat playing in warm natural light"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <div class="story-copy">
          <span class="eyebrow">Behavior is communication</span>
          <h2>
            Understand more.
            <br />
            <em>Care better.</em>
          </h2>
          <p class="section-body">
            Cats are masters of subtlety. CatPlay helps you recognize the quiet signals behind
            their behavior and respond with confidence.
          </p>
          <div class="story-list">
            <div>Track behavior and mood over time</div>
            <div>Discover patterns and triggers</div>
            <div>Build routines that support wellbeing</div>
          </div>
          <p class="story-footnote">
            It is not about changing your cat. It is about understanding them.
          </p>
        </div>
      </div>
    </section>

    <section id="features" class="features-section">
      <div class="container features-grid">
        {
          featureItems.map((feature) => (
            <article class="feature-card">
              <span class="section-number feature-number">{feature.number}</span>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="testimonial-section">
      <div class="container testimonial-grid">
        <div class="testimonial-copy">
          <span class="eyebrow">From our early community</span>
          <h2>
            "CatPlay changed how <em>I connect</em> with my cat."
          </h2>
          <p class="section-body">
            It helped me understand her stress signals and build a routine that finally works for
            both of us.
          </p>
          <div class="testimonial-meta">
            <div class="testimonial-author">Lea &amp; Miso</div>
            <div class="testimonial-role">Early CatPlay member</div>
          </div>
        </div>

        <div class="testimonial-media">
          <div class="media-frame testimonial-media-frame">
            <img
              src="/landing/testimonial-cat.jpg"
              alt="Calm cat resting close to its human"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="waitlist" class="waitlist-section">
      <div class="container waitlist-grid">
        <div class="waitlist-lead">
          <span class="eyebrow">Coming soon</span>
          <h2>
            Be the first
            <br />
            to <em>play.</em>
          </h2>
        </div>
        <p class="waitlist-body">
          Join the waitlist and be the first to get early access to CatPlay.
        </p>
        <div class="waitlist-form-column">
          <WaitlistForm
            id="waitlist-secondary"
            variant="editorial"
          />
        </div>
      </div>
    </section>

    <section id="faq" class="faq-section">
      <div class="container faq-shell">
        <span class="eyebrow">FAQ</span>
        <div class="faq-list">
          {
            faqItems.map((item, index) => (
              <details open={index === 0}>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .landing-shell {
    background: #fbf7f1;
    color: #2a2019;
  }

  .hero-section {
    padding: 8px 0 26px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.47fr) minmax(0, 0.53fr);
    gap: 26px;
    align-items: stretch;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 20px;
    padding: 72px 32px 72px 0;
  }

  .hero-copy h1 {
    max-width: 8ch;
  }

  .eyebrow {
    color: #c39a7b;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 600;
  }

  h1,
  h2 {
    font-size: clamp(50px, 7vw, 82px);
    line-height: 0.98;
    letter-spacing: -0.06em;
    font-weight: 400;
    color: #2a2019;
  }

  h1 em,
  h2 em {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-weight: 400;
    color: var(--editorial-italic-accent);
  }

  .hero-body,
  .section-body,
  .waitlist-body {
    max-width: 430px;
    color: rgba(72, 56, 44, 0.8);
    font-size: 17px;
    line-height: 1.75;
  }

  .hero-form {
    max-width: 460px;
  }

  .hero-form-mobile {
    display: none;
  }

  .hero-media,
  .story-media,
  .testimonial-media {
    display: flex;
  }

  .media-frame {
    width: 100%;
    overflow: hidden;
    background: #e7d8c9;
  }

  .media-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-media-frame {
    aspect-ratio: 1.04;
  }

  .trust-bar {
    border-top: 1px solid rgba(123, 97, 72, 0.1);
    border-bottom: 1px solid rgba(123, 97, 72, 0.1);
  }

  .trust-inner {
    display: grid;
    gap: 22px;
    padding-top: 26px;
    padding-bottom: 26px;
  }

  .trust-statement {
    color: #554337;
    font-family: "Instrument Serif", serif;
    font-size: 28px;
    line-height: 1.2;
    max-width: 640px;
  }

  .trust-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
  }

  .trust-logo-item {
    min-width: 112px;
    display: grid;
    gap: 2px;
  }

  .trust-logo-name {
    color: #b59f8b;
    font-size: 18px;
    line-height: 1.2;
    font-family: "Instrument Serif", serif;
  }

  .trust-logo-meta {
    color: #c3b2a1;
    font-size: 11px;
    letter-spacing: 0.14em;
  }

  .story-section {
    border-bottom: 1px solid rgba(123, 97, 72, 0.08);
  }

  .story-grid,
  .testimonial-grid,
  .waitlist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
  }

  .story-media-frame {
    aspect-ratio: 0.98;
    background: #e7dccf;
  }

  .story-copy {
    display: grid;
    align-content: center;
    gap: 18px;
    padding: 36px 0 36px 46px;
  }

  .story-list {
    margin-top: 6px;
  }

  .story-list div {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    color: #554337;
    padding: 12px 0;
    border-bottom: 1px solid rgba(123, 97, 72, 0.12);
  }

  .story-list div::before {
    content: "";
    width: 9px;
    height: 9px;
    margin-top: 8px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--apricot-500);
  }

  .story-footnote {
    margin-top: 8px;
    max-width: 360px;
    color: #5c483a;
    line-height: 1.7;
  }

  .features-section {
    padding: 24px 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .feature-card {
    padding: 10px 24px 10px 0;
    border-bottom: 1px solid rgba(123, 97, 72, 0.08);
    display: grid;
    gap: 14px;
  }

  .feature-number {
    margin-bottom: 2px;
  }

  .feature-card h3 {
    color: #372a22;
    font-size: 32px;
    line-height: 1.02;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  .feature-card p {
    max-width: 280px;
    color: rgba(76, 60, 47, 0.78);
    line-height: 1.7;
  }

  .testimonial-section {
    background: #f7eee4;
    border-top: 1px solid rgba(123, 97, 72, 0.06);
    border-bottom: 1px solid rgba(123, 97, 72, 0.06);
  }

  .testimonial-copy {
    display: grid;
    align-content: center;
    gap: 18px;
    padding: 48px 34px;
  }

  .testimonial-copy h2 {
    font-size: clamp(42px, 5.2vw, 50px);
    line-height: 1.04;
  }

  .testimonial-meta {
    margin-top: 8px;
    padding-top: 16px;
    border-top: 1px solid rgba(123, 97, 72, 0.12);
    max-width: 240px;
    display: grid;
    gap: 4px;
  }

  .testimonial-author {
    color: #413126;
    font-size: 20px;
    line-height: 1.3;
  }

  .testimonial-role {
    color: rgba(94, 75, 60, 0.72);
    font-size: 13px;
  }

  .testimonial-media-frame {
    min-height: 420px;
    background: #e6d7c9;
  }

  .waitlist-section {
    padding: 34px 0;
    border-bottom: 1px solid rgba(123, 97, 72, 0.08);
  }

  .waitlist-grid {
    grid-template-columns: minmax(0, 0.34fr) minmax(0, 0.26fr) minmax(0, 0.4fr);
    gap: 28px;
    align-items: center;
  }

  .waitlist-lead {
    display: grid;
    gap: 8px;
  }

  .waitlist-lead h2 {
    font-size: clamp(46px, 5vw, 52px);
    line-height: 1.02;
  }

  .waitlist-form-column {
    max-width: 520px;
  }

  .faq-section {
    padding: 48px 0;
  }

  .faq-shell {
    display: grid;
    gap: 20px;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-list details {
    border-top: 1px solid rgba(123, 97, 72, 0.08);
    padding-top: 12px;
  }

  .faq-list summary {
    list-style: none;
    cursor: pointer;
    color: #4b392d;
    font-size: 15px;
    line-height: 1.5;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .faq-list summary::-webkit-details-marker {
    display: none;
  }

  .faq-list summary::after {
    content: "+";
    color: #8b6c57;
    font-size: 20px;
    line-height: 1;
  }

  .faq-list details[open] summary::after {
    content: "-";
  }

  .faq-list p {
    margin-top: 10px;
    max-width: 640px;
    color: rgba(86, 68, 54, 0.72);
    font-size: 13px;
    line-height: 1.5;
  }

  @media (max-width: 1179px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

  .hero-copy {
      max-width: 680px;
      padding: 56px 0 8px;
    }

    .hero-media {
      max-width: 760px;
    }

    .waitlist-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }

  @media (max-width: 860px) {
    .story-grid,
    .testimonial-grid,
    .features-grid {
      grid-template-columns: 1fr;
    }

    .story-copy,
    .testimonial-copy {
      padding-left: 0;
      padding-right: 0;
    }

    .story-section,
    .testimonial-section {
      padding: 26px 0;
    }

    .story-media,
    .testimonial-media {
      order: -1;
      margin-bottom: 24px;
    }
  }

  @media (max-width: 680px) {
    .hero-section {
      padding-top: 0;
      padding-bottom: 22px;
    }

    .hero-grid {
      gap: 18px;
    }

    .hero-copy {
      padding-top: 34px;
      padding-bottom: 4px;
      gap: 14px;
    }

    .hero-copy h1 {
      max-width: 7ch;
      font-size: clamp(42px, 12vw, 50px);
      line-height: 0.98;
    }

    h1,
    h2 {
      line-height: 1.04;
    }

    .hero-body,
    .section-body,
    .waitlist-body {
      font-size: 16px;
      line-height: 1.65;
    }

    .hero-body {
      max-width: 31ch;
      font-size: 15.5px;
      line-height: 1.58;
    }

    .hero-form {
      max-width: none;
    }

    .hero-form-desktop {
      display: none;
    }

    .hero-form-mobile {
      display: block;
      max-width: none;
      order: 3;
    }

    .hero-media {
      margin: 0 -20px;
      max-width: none;
    }

    .hero-media-frame {
      aspect-ratio: 0.92;
    }

    .hero-benefits {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 28px;
    }

    .hero-benefit {
      gap: 10px;
      font-size: 12px;
      line-height: 1.25;
    }

    .hero-benefit-icon {
      width: 48px;
      height: 48px;
    }

    .hero-benefit-icon svg {
      width: 22px;
      height: 22px;
    }

    .trust-statement {
      font-size: 22px;
    }

    .trust-logos {
      gap: 0;
    }

    .feature-card h3 {
      font-size: 26px;
    }

    .testimonial-copy h2,
    .waitlist-lead h2 {
      font-size: 38px;
    }

    .testimonial-media-frame {
      min-height: 320px;
    }
  }
</style>
